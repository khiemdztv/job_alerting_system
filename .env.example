# Telegram Bot Token (obtain from @BotFather on Telegram)
VIECLAMBOT_TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# AWS Configuration
VIECLAMBOT_AWS_REGION=ap-southeast-1
VIECLAMBOT_DYNAMODB_JOBS_TABLE=vieclambot-jobs
VIECLAMBOT_DYNAMODB_USERS_TABLE=vieclambot-users
VIECLAMBOT_DYNAMODB_SUBSCRIPTIONS_TABLE=vieclambot-subscriptions
VIECLAMBOT_S3_DATA_LAKE_BUCKET=vieclambot-data-lake-your_bucket_id_here
VIECLAMBOT_SQS_RAW_JOBS_QUEUE=vieclambot-raw-jobs

# Scraper APIs
VIECLAMBOT_JOOBLE_API_KEY=your_jooble_api_key_here

# Logging
VIECLAMBOT_LOG_LEVEL=INFO
